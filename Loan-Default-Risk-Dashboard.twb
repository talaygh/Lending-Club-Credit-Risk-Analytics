          <zone forceUpdate='true' h='52333' id='3' type-v2='text' w='98858' x='571' y='889'>
            <formatted-text>
              <run bold='true' fontcolor='#1b1b1b' fontname='Benton Sans Book' fontsize='12'>Methodology</run>
              <run>Æ&#10;&#10;</run>
              <run bold='true' fontcolor='#1b1b1b' fontname='Benton Sans Book' fontsize='12'>Data: Lending Club 2007–2018, 500K stratified sample (from 2.26M)</run>
              <run>Æ&#10;</run>
              <run bold='true' fontcolor='#1b1b1b' fontname='Benton Sans Book' fontsize='12'>Model: XGBoost, isotonic-calibrated, AUC 0.73</run>
              <run>Æ&#10;</run>
              <run bold='true' fontcolor='#1b1b1b' fontname='Benton Sans Book' fontsize='12'>Features: 47 engineered (excludes 23 post-default leakage fields)</run>
              <run>Æ&#10;</run>
              <run bold='true' fontcolor='#1b1b1b' fontname='Benton Sans Book' fontsize='12'>Validation: Stratified split, average precision + Brier score</run>
              <run>Æ&#10;</run>
              <run bold='true' fontcolor='#1b1b1b' fontname='Benton Sans Book' fontsize='12'>Risk Decile: 16x separation (top vs bottom decile default rates)</run>
              <run>Æ&#10;&#10;</run>
              <run bold='true' fontcolor='#1b1b1b' fontname='Benton Sans Book' fontsize='12'>Limitations:</run>
              <run>Æ&#10;</run>
              <run bold='true' fontcolor='#1b1b1b' fontname='Benton Sans Book' fontsize='12'>- Random split (production would use forward-time)</run>
              <run>Æ&#10;</run>
              <run bold='true' fontcolor='#1b1b1b' fontname='Benton Sans Book' fontsize='12'>- LGD assumed at 0.75 (sensitivity analysis would refine)</run>
              <run>Æ&#10;</run>
              <run bold='true' fontcolor='#1b1b1b' fontname='Benton Sans Book' fontsize='12'>- Time value of money not discounted</run>
            </formatted-text>
            <zone-style>
              <format attr='border-color' value='#000000' />
              <format attr='border-style' value='none' />
              <format attr='border-width' value='0' />
